#ifndef SECRETS_H_EXAMPLE
#define SECRETS_H_EXAMPLE

// 复制此文件为 secrets.h 并填入你的实际配置
// cp secrets.h.example secrets.h

// WiFi配置
#define WIFI_SSID "your_wifi_ssid"
#define WIFI_PASSWORD "your_wifi_password"
#define WIFI_MAXIMUM_RETRY 5

// 百度AI配置
// 方式1: 传统API Key认证（推荐，用于语音技术+文心共用）
#define BAIDU_API_KEY "your_baidu_api_key"
#define BAIDU_SECRET_KEY "your_baidu_secret_key"
#define BAIDU_APP_ID "your_baidu_app_id"

// 方式2: 千帆IAM认证（如果千帆控制台只提供此格式）
// 取消下面的注释并填入千帆API Key
// #define QIANFAN_API_KEY "bce-v3/ALTAK-xxx/yyy"

// I2S引脚配置（根据实际硬件修改）
#define I2S_MIC_BCK_IO     41
#define I2S_MIC_WS_IO      42
#define I2S_MIC_DI_IO      2
#define I2S_SPK_BCK_IO     17
#define I2S_SPK_WS_IO      18
#define I2S_SPK_DO_IO      8

#endif // SECRETS_H_EXAMPLE
